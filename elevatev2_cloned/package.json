{
  "name": "elevate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd server && npm run dev",
    "dev:auth": "cd backend && npm run dev",
    "dev:all": "concurrently --names \"VITE,API,AUTH\" --prefix-colors \"cyan,green,yellow\" \"vite --port 5001\" \"cd server && npm run dev\" \"cd backend && npm run dev\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "wait-on tcp:5001 && cross-env NODE_ENV=development electron .",
    "start": "concurrently \"npm run dev -- --port 5001\" \"npm run electron\""
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
